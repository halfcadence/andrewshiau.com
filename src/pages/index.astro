---
import Layout from '../layouts/Layout.astro';
import { experiments } from '../data/experiments';
---

<Layout title="Andrew Shiau — AI experiments">
  <!-- Masthead — the wordmark in the nav already says the name; don't repeat it. -->
  <div class="grid" style="margin-top:calc(var(--unit)*1.5)">
    <h1 class="c1-10">I'm Andrew. I design and build <span class="lately">— lately with AI.</span></h1>
  </div>

  <!-- Experiments — calendar-scatter matrix (Layout A). The empty modules
       between cells are the composition. -->
  <div class="grid" style="margin-top:calc(var(--unit)*2)">
    <div class="rule"></div>
    <div style="grid-column:1 / 5"><h2>Experiments</h2></div>
  </div>

  <div class="matrix">
    {experiments.map((x) => (
      <a class={`entry ${x.pos} ${x.accent ? 'accent' : ''}`} href={x.href}
         target={x.external ? '_blank' : undefined} rel={x.external ? 'noopener' : undefined}>
        <span class="en">{x.n}</span>
        <p class="eh">{x.title} <span class="arrowc">{x.external ? '↗' : '→'}</span></p>
        <p class="ed">{x.blurb}</p>
        <span class="em">{x.meta}</span>
      </a>
    ))}
  </div>

  <!-- Colophon — placed on the grid, not stacked full-width. Label column at the
       left, three facts as aligned satellites; the right columns stay empty. -->
  <div class="grid" style="margin-top:calc(var(--unit)*3)">
    <div class="colo-rule"></div>
    <div class="colo-lab">Colophon</div>
    <div class="colo c1">
      <span class="ck">Contact</span>
      <a href="mailto:hi@andrewshiau.com">hi@andrewshiau.com</a>
    </div>
    <div class="colo c2">
      <span class="ck">Elsewhere</span>
      <a href="https://github.com/halfcadence">github</a>
    </div>
    <div class="colo c3">
      <span class="ck">Before AI</span>
      <a href="https://2018.andrewshiau.com">portfolio2018</a>
    </div>
    <div class="colo c4">
      <span class="ck">This site</span>
      Graphik · 12-col grid
    </div>
  </div>
</Layout>
