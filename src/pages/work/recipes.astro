---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="A recipe system — Andrew Shiau"
  description="A hand-built, agent-maintained collection of 120+ recipes and cooking essays."
>
  <div class="grid">
    <div class="back"><a href="/">← Index</a></div>
  </div>

  <div class="grid">
    <div class="c1-2"><span class="sn">02</span></div>
    <div class="c3-12"><h1>A recipe system</h1></div>
  </div>
  <div class="grid">
    <p class="dek c1-8" style="margin-top:var(--unit)">
      A living collection of 120+ recipes and cooking essays — Japanese, Korean,
      French pastry, specialty coffee — organized like a reference manual, not a
      blog. An AI agent helps write, edit, and file each entry against a fixed
      style guide.
    </p>
  </div>

  <div class="grid">
    <div class="idea">
      <p class="k">Why it exists</p>
      <p>Precision cooking deserves the same typographic care as anything else.</p>
    </div>
  </div>

  <div class="grid">
    <div class="rule"></div>
  </div>

  <!-- Facts -->
  <div class="grid">
    <div class="facts">
      <div class="frow">
        <div class="fm">Contents</div>
        <div class="ftx">
          <b>124 recipes</b> across mains, soups & hot pots, sides, sweets, drinks,
          and pantry — plus 20 technique essays.
        </div>
      </div>
      <div class="frow">
        <div class="fm">Stack</div>
        <div class="ftx">
          Jekyll · GitHub Pages · self-owned CSS (no theme) · system Helvetica.
        </div>
      </div>
      <div class="frow">
        <div class="fm">The agent's job</div>
        <div class="ftx">
          Drafts and files new recipes against a committed <b>steering.md</b>
          style guide — numbered sections, consistent measurements, a maintained
          changelog. The human tastes; the agent keeps the archive tidy.
        </div>
      </div>
    </div>
  </div>

  <!-- Screenshot placeholder — replaced with a real capture in Phase A step 5 -->
  <div class="grid">
    <figure class="shot c1-10">
      <img src="/shots/recipes.png" alt="The recipes collection homepage" />
      <figcaption>halfcadence.github.io/recipes — homepage archive index</figcaption>
    </figure>
  </div>

  <!-- Outbound -->
  <div class="grid">
    <div class="rule"></div>
  </div>
  <div class="grid">
    <div class="links">
      <a href="https://halfcadence.github.io/recipes/" target="_blank" rel="noopener">
        Visit the recipe collection ↗
        <span class="lu">halfcadence.github.io/recipes</span>
      </a>
    </div>
  </div>
</Layout>
