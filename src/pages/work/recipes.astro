---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Recipes — Andrew Shiau"
  description="124 recipes and cooking essays, kept in order by an agent against a fixed style guide."
>
  <div class="grid">
    <div class="back"><a href="/">← Index</a></div>
  </div>

  <div class="grid">
    <div class="c1-2"><span class="sn">01</span></div>
    <div class="c3-12"><h1>Recipes</h1></div>
  </div>
  <div class="grid">
    <p class="dek c1-8" style="margin-top:var(--unit)">
      124 recipes and cooking essays — Japanese, Korean, French pastry, coffee.
      Filed like a reference manual, not a blog. An agent drafts and files each
      entry against a fixed style guide; I do the cooking.
    </p>
  </div>

  <div class="grid">
    <div class="rule"></div>
  </div>

  <!-- Facts -->
  <div class="grid">
    <div class="facts">
      <div class="frow">
        <div class="fm">Contents</div>
        <div class="ftx">
          <b>124 recipes</b> across mains, soups & hot pots, sides, sweets, drinks,
          and pantry — plus 20 technique essays.
        </div>
      </div>
      <div class="frow">
        <div class="fm">Stack</div>
        <div class="ftx">
          Jekyll · GitHub Pages · own CSS, no theme · system Helvetica.
        </div>
      </div>
      <div class="frow">
        <div class="fm">Agent's job</div>
        <div class="ftx">
          Files new recipes against a committed <b>steering.md</b> — numbered
          sections, consistent measures, a maintained changelog. Keeps the archive
          tidy so I don't have to.
        </div>
      </div>
    </div>
  </div>

  <!-- Live embed of the real site — not a screenshot -->
  <div class="grid">
    <figure class="embed c1-12">
      <div class="embed-frame">
        <iframe src="https://halfcadence.github.io/recipes/" title="The recipes collection, live"
          loading="lazy" referrerpolicy="no-referrer"></iframe>
      </div>
      <figcaption>
        <a href="https://halfcadence.github.io/recipes/" target="_blank" rel="noopener">halfcadence.github.io/recipes ↗</a>
        — live, embedded
      </figcaption>
    </figure>
  </div>
</Layout>
